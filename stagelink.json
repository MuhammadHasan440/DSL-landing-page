{
  "name": "contact-form-api",
  "version": "1.0.0",
  "runtime": "nodejs18",
  "functions": {
    "contact": {
      "path": "/api/contact",
      "handler": "api/contact.handler",
      "memory": 1024,
      "timeout": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "exclude": [
      "node_modules/.bin",
      ".git",
      ".env.example",
      "*.test.js",
      "README.md",
      "vercel.json"
    ]
  }
}